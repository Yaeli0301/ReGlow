# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# demo | production — demo uses in-memory Mongo when MONGODB_URI is unset (local only)
ENV_MODE=production

# MongoDB (production / demo-with-uri)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/reglow

# Optional separate DB for demo deployments (never share with production)
MONGODB_URI_DEMO=mongodb+srv://user:password@cluster.mongodb.net/reglow_demo

# JWT (min 32 characters)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Price IDs (create in Stripe Dashboard, currency ILS)
STRIPE_PRICE_BASIC=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_PREMIUM=price_...

# Vercel Cron (set in Vercel dashboard)
CRON_SECRET=your-cron-secret-min-16-chars

# Models: User, Client, Appointment, Service, WeeklySchedule, DateOverride, Referral, ReactivationLog
