# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# production | demo — demo MUST use MONGODB_URI_DEMO (separate DB)
ENV_MODE=production

# Allow "Try demo" from landing in production (sales demos)
ENABLE_LANDING_DEMO=true

# MongoDB Atlas — production (database name: reglow)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/reglow?retryWrites=true&w=majority&appName=Cluster0
# If querySrv fails on Windows, use "Standard connection string" from Atlas instead:
# MONGODB_URI_STANDARD=mongodb://USER:PASSWORD@host1:27017,host2:27017/reglow?ssl=true&authSource=admin

# Demo only — never the same DB as production
MONGODB_URI_DEMO=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/reglow_demo?retryWrites=true&w=majority

# JWT (min 32 characters)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Price IDs (create in Stripe Dashboard, currency ILS)
STRIPE_PRICE_BASIC=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_PREMIUM=price_...

# Cron (Vercel or external cron hitting Render)
CRON_SECRET=your-cron-secret-min-16-chars

# Optional: sync .env.local → Render (scripts/sync-render-env.mjs)
# RENDER_API_KEY=rnd_...
# RENDER_SERVICE_ID=srv-...
