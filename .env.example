# === Production deploy (this site) ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
ENV_MODE=production

# MongoDB Atlas — production only (database: reglow)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/reglow?retryWrites=true&w=majority&appName=Cluster0

# JWT (min 32 characters)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# Stripe, CRON, email — see docs/VERCEL-SETUP.md

# Do NOT set ENABLE_LANDING_DEMO on production.
# Demo lives on a separate Vercel project + external landing page.

# === Separate demo deploy (another Vercel project) ===
# ENV_MODE=demo
# MONGODB_URI_DEMO=mongodb+srv://...@cluster/reglow_demo?...
# NEXT_PUBLIC_PRODUCTION_URL=https://re-glow-vhp6.vercel.app
# NEXT_PUBLIC_APP_URL=https://your-demo-project.vercel.app
